# colligo データ移行用 環境設定テンプレート
#
# このファイルは、旧環境と新環境のそれぞれで使用される環境変数を定義します。
# 移行時には、各環境で適切に設定してください。
#
# ============================================================================
# 旧環境（データエクスポート時）の例
# ============================================================================
# .env.old:
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=your_old_password
#   POSTGRES_DB=colligo
#   POSTGRES_PORT=5432
#   DATABASE_URL=postgresql://postgres:your_old_password@old-db-host:5432/colligo
#   NODE_ENV=production
#   PORT=3000

# ============================================================================
# 新環境（データインポート時）の例
# ============================================================================
# .env.new:
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=your_new_password
#   POSTGRES_DB=colligo_new
#   POSTGRES_PORT=5432
#   DATABASE_URL=postgresql://postgres:your_new_password@new-db-host:5432/colligo_new
#   NODE_ENV=production
#   PORT=3000

# ============================================================================
# 説明
# ============================================================================

# POSTGRES_USER
# - PostgreSQL のスーパーユーザー名
# - デフォルト: postgres
# - 推奨: 新環境でも同じ値を使用（バックアップ・リストア互換性のため）
POSTGRES_USER=postgres

# POSTGRES_PASSWORD
# - PostgreSQL のスーパーユーザーパスワード
# - 注意: バージョン管理システムに保存しないこと
# - 各環境で異なる値を設定すること（セキュリティ）
POSTGRES_PASSWORD=password_change_me_in_production

# POSTGRES_DB
# - PostgreSQL のデータベース名
# - デフォルト: colligo
# - 推奨: 旧環境と新環境で同じ名前を使用（スクリプト互換性のため）
POSTGRES_DB=colligo

# POSTGRES_PORT
# - PostgreSQL のポート番号
# - デフォルト: 5432
# - Docker Compose 内: db コンテナの場合は 5432
# - 外部接続: ホストマシンから接続する場合は異なる値を指定可能
POSTGRES_PORT=5432

# DATABASE_URL
# - Prisma が使用するデータベース接続文字列
# - 形式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# - Docker Compose 環境の場合: ホスト名は db コンテナ名
# - 注意: パスワード内の特殊文字は URL エンコードが必要な場合あり
DATABASE_URL=postgresql://postgres:password_change_me_in_production@db:5432/colligo

# NODE_ENV
# - Node.js 環境指定
# - production または development
# - 移行時は production を推奨
NODE_ENV=production

# PORT
# - API サーバーのバインドポート
# - デフォルト: 3000
PORT=3000

# ============================================================================
# マイグレーション用チェックリスト
# ============================================================================

# 旧環境でのエクスポート前:
# [ ] POSTGRES_USER, POSTGRES_PASSWORD が正しいことを確認
# [ ] POSTGRES_DB が正しいことを確認
# [ ] データベースが起動していることを確認
# [ ] 十分なディスク領域があることを確認（ダンプファイル用）

# 新環境でのインポート前:
# [ ] DATABASE_URL が新環境の DB ホスト名に更新されていることを確認
# [ ] POSTGRES_PASSWORD が新環境用に変更されていることを確認
# [ ] 新環境のデータベースが起動していることを確認
# [ ] 古いデータが存在しないことを確認（必要に応じてクリア）

# ============================================================================
# トラブルシューティング
# ============================================================================

# Q: DATABASE_URL が正しくないエラーが出る場合
# A: 以下を確認してください:
#    - ホスト名: Docker Compose 内では \"db\" を使用
#    - ポート: デフォルトは 5432
#    - パスワード内の特殊文字（@, %, :）は URL エンコードが必要
#      例: password@123 → password%40123

# Q: 接続できないエラー
# A: 以下を確認してください:
#    - DB コンテナが起動しているか: docker compose ps
#    - ネットワーク接続: docker exec api nc -zv db 5432
#    - ファイアウォール設定: 必要に応じて解放

# Q: パーミッションエラー
# A: POSTGRES_USER が正しく設定されていることを確認
#    pg_dump 実行時は POSTGRES_USER でアクセス可能な DB を指定

# ============================================================================
# 参考: Docker Compose での環境変数の使用
# ============================================================================

# compose.yml では以下のように .env ファイルの値を参照します:
#
#   environment:
#     POSTGRES_USER: ${POSTGRES_USER:-postgres}
#     POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-password}
#     DATABASE_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
#
# 複数の .env ファイルを使い分ける場合:
#   docker compose --env-file .env.migration up -d db
