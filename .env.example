# Copy this file to .env and fill in your values

# ── PostgreSQL (local dev) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/colligo?schema=public"

# ── PostgreSQL (docker-compose overrides) ────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=colligo
POSTGRES_PORT=5432

# ── API server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── RSS worker ────────────────────────────────────────────────────────────────
# How often to poll feeds, in milliseconds (default: 3 600 000 = 1 hour)
FETCH_INTERVAL_MS=3600000
# Maximum number of feeds fetched concurrently in each cycle (default: 5)
WORKER_CONCURRENCY=5

# ── Logging ───────────────────────────────────────────────────────────────────
# Verbosity level: error | warn | info | http | debug | silly (default: info)
LOG_LEVEL=info
